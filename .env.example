# API Keys for providers
# Copy this to .env and fill in your keys.
#
# Required: WISGATE_API_KEY, COMET_API_KEY (both return 401 on /v1/models
# without a valid key) and FIRECRAWL_API_KEY (for the --enrich scrape path).
#
# Optional: OPENROUTER_API_KEY and REQUESTY_API_KEY — both providers serve
# their /v1/models endpoint unauthenticated (200, full data). Set these
# only if you plan to actually call the chat endpoints.

WISGATE_API_KEY=        # required
COMET_API_KEY=          # required
OPENROUTER_API_KEY=     # optional (discovery is public)
REQUESTY_API_KEY=       # optional (discovery is public)

# Scraping services
FIRECRAWL_API_KEY=      # required for --enrich